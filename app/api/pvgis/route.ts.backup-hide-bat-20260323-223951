    return {
      monthlyAvg,
      yearlyAvg,
      maxHourlyWind: maxWindAtHeight,
      estimatedMaxGust: maxWindAtHeight * gustFactor,
      gustFactor,
      turbineHeight: TURBINE_HEIGHT_M,
      dataSource: 'Open-Meteo ERA5'
    };
  } catch (error) {
    console.error('Open-Meteo wind fetch error:', error);
    return null;
  }
}

